generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  INSPECTOR
  ADMIN
}

enum OrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  QUALITY_CHECK
  DELIVERED
  CANCELLED
}

enum Formula {
  ESSENTIEL
  STANDARD
  PREMIUM
}

enum PaymentMethod {
  CARD
  WAFACASH
  WIRE
  WESTERN_UNION
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum InspectorBadge {
  STARTER
  PRO
  EXPERT
}

enum SubscriptionPlan {
  STARTER
  PRO
  EXPERT
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  DELIVERED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  phone         String?
  image         String?
  password      String?
  role          UserRole  @default(CLIENT)
  referralCode  String?   @unique
  referredById  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referredBy        User?              @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]             @relation("Referrals")
  accounts          Account[]
  sessions          Session[]
  inspectorProfile  InspectorProfile?
  clientOrders      Order[]            @relation("ClientOrders")
  inspectorOrders   Order[]            @relation("InspectorOrders")
  notifications     Notification[]
  reviews           Review[]           @relation("ClientReviews")
  inspectorReviews  Review[]           @relation("InspectorReviews")
  referralCredits   ReferralCredit[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InspectorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  bio                String?            @db.Text
  cities             String[]
  badge              InspectorBadge     @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(EXPIRED)
  subscriptionEnd    DateTime?
  rating             Float              @default(0)
  totalMissions      Int                @default(0)
  certifications     String[]
  idPhotoUrl         String?
  isApproved         Boolean            @default(false)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  reports       Report[]

  @@index([isApproved])
}

model Order {
  id                          String        @id @default(cuid())
  clientId                    String
  inspectorId                 String?
  status                      OrderStatus   @default(PENDING)
  formula                     Formula
  propertyAddress             String
  propertyCity                String
  propertyType                String
  surfaceArea                 Float?
  clientPhotos                String[]
  notes                       String?       @db.Text
  clientPrice                 Float
  inspectorShare              Float?
  margin                      Float?
  paymentMethod               PaymentMethod
  paymentStatus               PaymentStatus @default(PENDING)
  stripeSessionId             String?
  paymentProofUrl             String?
  paymentAmountPaid           Float?
  paymentConfirmedByAdmin     Boolean       @default(false)
  paymentConfirmedByClient    Boolean       @default(false)
  paymentConfirmedByInspector Boolean       @default(false)
  cashAmountByClient          Float?
  cashAmountByInspector       Float?
  cashMismatch                Boolean       @default(false)
  scheduledDate               DateTime?
  referralCodeUsed            String?
  creditApplied               Float         @default(0)
  adminNotes                  String?       @db.Text
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  deliveredAt                 DateTime?

  client    User    @relation("ClientOrders", fields: [clientId], references: [id])
  inspector User?   @relation("InspectorOrders", fields: [inspectorId], references: [id])
  report    Report?
  review    Review?

  @@index([clientId])
  @@index([inspectorId])
  @@index([status])
  @@index([propertyCity])
}

model Report {
  id                   String       @id @default(cuid())
  orderId              String       @unique
  inspectorId          String
  status               ReportStatus @default(DRAFT)
  checklistData        Json?
  photos               String[]
  videoUrl             String?
  pdfUrl               String?
  inspectorNotes       String?      @db.Text
  adminNotes           String?      @db.Text
  estimatedRepairMin   Float?
  estimatedRepairMax   Float?
  estimatedMarketValue Float?
  recommendation       String?
  submittedAt          DateTime?
  approvedAt           DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inspector InspectorProfile @relation(fields: [inspectorId], references: [id])

  @@index([orderId])
  @@index([inspectorId])
  @@index([status])
}

model Subscription {
  id               String             @id @default(cuid())
  inspectorId      String
  plan             SubscriptionPlan
  price            Float
  startDate        DateTime
  endDate          DateTime
  status           SubscriptionStatus @default(ACTIVE)
  paymentMethod    PaymentMethod      @default(CARD)
  stripeSessionId  String?
  paymentProofUrl  String?
  confirmedByAdmin Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  inspector InspectorProfile @relation(fields: [inspectorId], references: [id], onDelete: Cascade)

  @@index([inspectorId])
  @@index([status])
  @@index([endDate])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  clientId    String
  inspectorId String
  rating      Int
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  client    User  @relation("ClientReviews", fields: [clientId], references: [id])
  inspector User  @relation("InspectorReviews", fields: [inspectorId], references: [id])
}

model ReferralCredit {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  description   String
  orderId       String?
  usedOnOrderId String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CashConfirmationLog {
  id        String   @id @default(cuid())
  orderId   String
  actor     String
  actorRole UserRole
  amount    Float
  event     String
  createdAt DateTime @default(now())

  @@index([orderId])
}
